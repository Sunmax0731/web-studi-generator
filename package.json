{
  "name": "web-studi-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "archive:materials": "node scripts/archive-materials.mjs",
    "dev": "npm run generate && vite preview --host 127.0.0.1 --port 4173",
    "build": "npm run generate",
    "test": "node --test tests/unit/*.test.mjs",
    "e2e": "playwright test --config=playwright.config.mjs",
    "lint": "eslint .",
    "preview": "npm run generate && vite preview --host 127.0.0.1 --port 4173",
    "docs:zip": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (!(Test-Path release)) { New-Item -ItemType Directory release | Out-Null }; Compress-Archive -Path README.md,AGENTS.md,SKILL.md,TODO.md,docs -DestinationPath release/web-studi-generator-docs.zip -Force\""
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
